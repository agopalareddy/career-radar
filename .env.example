# Copy to .env and fill in. .env is gitignored — secrets and personal paths
# never enter the repository.

# Reddit "script" app credentials — create one at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Reddit requires a descriptive user agent; include your username.
REDDIT_USER_AGENT=career-radar/1.0 by u/yourusername

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Local grounding files (absolute paths, OUTSIDE this repo).
# CV_PATH: your CV as .pdf (needs poppler-utils/pdftotext), .md, or .txt
CV_PATH=/absolute/path/to/your/cv.pdf
# WEBSITE_DIR (optional): a folder of .md/.txt/.html describing your work,
# e.g. the source of your personal website.
WEBSITE_DIR=
